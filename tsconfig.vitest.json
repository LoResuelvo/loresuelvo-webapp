{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noEmit": true
  },
  "include": [
    "vitest.config.ts",
    "vitest.setup.ts",
    "components/**/*.ts",
    "components/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
