# Copy this file to .env.local for local development.
# Release deploys create .env on each droplet from the GitHub workflow.
# NEVER commit real values: only this example file goes to Git.

NODE_ENV=development
APP_ENV=development
APP_URL=http://localhost:3001
API_URL=http://localhost:8080

# Configuración de Auth0
# The tenant domain Auth0 (ej: dev-xxx.us.auth0.com)
AUTH0_DOMAIN=https://auth.{domain}
# The cliend ID from your app (Regular Web App)
AUTH0_CLIENT_ID={your-client-id}
# The client secret from auth0
AUTH0_CLIENT_SECRET={your-client-secret}
# A random secret with 32 characters (openssl rand -hex 32)
AUTH0_SECRET={your-32-char-random-secret}
# The base URL of your application (http://localhost:3000 for dev)
AUTH0_BASE_URL=http://localhost:3000